// OP2: find() — retrieve all Electronics products with price > 20000
db.products.find(
  { category: "Electronics", price: { $gt: 20000 } },
  { name: 1, category: 1, price: 1, _id: 0 }
);

// OP3: find() — retrieve all Groceries expiring before 2025-01-01
db.products.find(
  {
    category: "Groceries",
    "specifications.expiry_date": { $lt: new Date("2025-01-01") }
  },
  { name: 1, "specifications.expiry_date": 1, _id: 0 }
);

// OP4: updateOne() — add a "discount_percent" field to a specific product
db.products.updateOne(
  { _id: "PROD_E001" },
  { $set: { discount_percent: 10 } }
);

// OP5: createIndex() — create an index on category field and explain why
// WHY: The most common query pattern is filtering by category (Electronics, Clothing, Groceries).
// Without an index, MongoDB scans every document (full collection scan).
// With this index, lookups by category become O(log n) instead of O(n),
// dramatically speeding up queries as the catalog grows to thousands of products.
db.products.createIndex({ category: 1 });